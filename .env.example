# PaperDoctor AI — Environment Variables

# Google Gemini API key (free tier available at aistudio.google.com)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# NCBI API key (free at https://ncbi.nlm.nih.gov/account)
# Recommended for higher PubMed rate limits (10 req/s without key, 10 req/s with key)
NCBI_API_KEY=

# Your email address — required by OpenAlex "polite pool" (better rate limits)
CONTACT_EMAIL=
